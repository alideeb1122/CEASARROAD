{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:file((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+)/",
      "destination": "/:file",
      "internal": true,
      "missing": [
        {
          "type": "header",
          "key": "x-nextjs-data"
        }
      ],
      "statusCode": 308,
      "regex": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+))/$"
    },
    {
      "source": "/:notfile((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+)",
      "destination": "/:notfile/",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+))$"
    }
  ],
  "headers": [],
  "dynamicRoutes": [
    {
      "page": "/en/services/[serviceSlug]",
      "regex": "^/en/services/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPserviceSlug": "nxtPserviceSlug"
      },
      "namedRegex": "^/en/services/(?<nxtPserviceSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/en/services/[serviceSlug]/[itemSlug]",
      "regex": "^/en/services/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPserviceSlug": "nxtPserviceSlug",
        "nxtPitemSlug": "nxtPitemSlug"
      },
      "namedRegex": "^/en/services/(?<nxtPserviceSlug>[^/]+?)/(?<nxtPitemSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/services/[serviceSlug]",
      "regex": "^/services/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPserviceSlug": "nxtPserviceSlug"
      },
      "namedRegex": "^/services/(?<nxtPserviceSlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/services/[serviceSlug]/[itemSlug]",
      "regex": "^/services/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPserviceSlug": "nxtPserviceSlug",
        "nxtPitemSlug": "nxtPitemSlug"
      },
      "namedRegex": "^/services/(?<nxtPserviceSlug>[^/]+?)/(?<nxtPitemSlug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/branches",
